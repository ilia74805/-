<Window x:Class="WpfApp9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp9"
        mc:Ignorable="d"               
        Title= "Космические захватчики" Height="500 "   Width="800" FocusManager.FocusedElement="{Binding ElementName=My_canvas}"> 
    <Canvas Name= "My_canvas" Focusable = "True" KeyDown="Canvas_KeyIsDown" KeyUp="Canvas_KeyIsUp">
        <Canvas.Background>
            <ImageBrush ImageSource="/Background.png"     />
            </Canvas.Background>
        <Label Foreground="White" Name="enemyleft" FontSize="16" FontWeight="ExtraBold">врагов осталось:</Label>
        <Rectangle Name="mainHero" Fill="White" Height="65" Width="56" Canvas.Left="372" Canvas.Top="391"></Rectangle>
    </Canvas>
</Window>
